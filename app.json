{
  "expo": {
    "name": "Helping Hand AI",
    "slug": "helping-hand-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "helpinghandai",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.helpinghand.ai",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Used to take a photo of your meal so the app can estimate its nutrition.",
        "NSPhotoLibraryUsageDescription": "Used to pick a photo of your meal so the app can estimate its nutrition."
      }
    },
    "android": {
      "package": "com.helpinghand.ai"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png",
      "backgroundColor": "#0D0D0D"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-image-picker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ea33d9d5-5fa5-4e6f-9d64-8863e07f028a"
      }
    },
    "owner": "iceking12"
  }
}
